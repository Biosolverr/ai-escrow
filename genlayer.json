    "mainnet": {
      "rpc_url": "https://rpc.genlayer.com",
      "chain_id": 42420
    }
  },
  "testing": {
    "test_dir": "tests",
    "mock_llm": true,
    "llm_provider": "openai/gpt-4o"
  }
}
